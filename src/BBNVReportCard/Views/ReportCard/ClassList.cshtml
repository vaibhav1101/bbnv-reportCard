@model List<Student>
@{
    ViewData["Title"] = "Class List";
    string className = ViewBag.ClassName;
    string section = ViewBag.Section;
    string term = ViewBag.Term;
    string academicYear = ViewBag.AcademicYear;
}

<h4>@className - @section &nbsp;|&nbsp; @term @academicYear</h4>
<p class="text-muted">@Model.Count student(s) found</p>

<table class="table table-hover table-bordered">
    <thead class="table-primary">
        <tr>
            <th>Roll No</th>
            <th>Student Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.RollNumber</td>
                <td>@s.StudentName</td>
                <td>
                    <a asp-action="Generate" asp-route-studentId="@s.StudentId"
                       asp-route-term="@term"
                       asp-route-academicYear="@academicYear"
                       class="btn btn-sm btn-outline-primary">View Card</a>
                    <a asp-action="Pdf" asp-route-studentId="@s.StudentId"
                       asp-route-term="@term"
                       asp-route-academicYear="@academicYear"
                       class="btn btn-sm btn-outline-danger">PDF</a>
                </td>
            </tr>
        }
    </tbody>
</table>
